    {
      "parameters": {
        "jsCode": "// Parse RSS XML response and extract articles\nconst response = $json.data || (typeof $json === 'string' ? $json : '');\n\nif (!response || typeof response !== 'string') {\n  return [];\n}\n\n// Helper: strip ALL HTML tags and decode entities\nfunction stripHtml(str) {\n  if (!str) return '';\n  return str\n    .replace(/<!\\[CDATA\\[/g, '').replace(/\\]\\]>/g, '')\n    .replace(/<[^>]*>/g, ' ')\n    .replace(/&amp;/g, '&').replace(/&lt;/g, '<').replace(/&gt;/g, '>')\n    .replace(/&quot;/g, '\"').replace(/&#39;/g, \"'\")\n    .replace(/&nbsp;/g, ' ')\n    .replace(/\\s+/g, ' ')\n    .trim();\n}\n\nconst articles = [];\nconst itemRegex = /<item>([\\s\\S]*?)<\\/item>/g;\nlet match;\n\nwhile ((match = itemRegex.exec(response)) !== null) {\n  const xml = match[1];\n\n  // Extract raw tag content\n  const getRawTag = (tag) => {\n    const m = xml.match(new RegExp(`<${tag}[^>]*>([\\\\s\\\\S]*?)<\\\\/${tag}>`));\n    return m ? m[1] : '';\n  };\n\n  const sourceMatch = xml.match(/<source[^>]*>([\\s\\S]*?)<\\/source>/);\n  const sourceName = sourceMatch ? stripHtml(sourceMatch[1]) : 'Google News';\n\n  const rawTitle = stripHtml(getRawTag('title'));\n  const title = rawTitle.replace(new RegExp(`\\\\s*-\\\\s*${sourceName.replace(/[.*+?^${}()|[\\\\]\\\\\\\\]/g, '\\\\\\\\$&')}\\\\s*$`), '') || rawTitle;\n\n  const linkMatch = xml.match(/<link>\\s*([\\s\\S]*?)\\s*<\\/link>/) || xml.match(/<link[^>]*href=[\"']([^\"']*)[\"']/);\n  const link = linkMatch ? linkMatch[1].trim() : '';\n\n  const pubDate = stripHtml(getRawTag('pubDate'));\n  const description = stripHtml(getRawTag('description'));\n\n  articles.push({\n    json: {\n      title: title,\n      description: description || '',\n      content: description || '',\n      author: '',\n      source: { name: sourceName },\n      url: link,\n      urlToImage: '',\n      publishedAt: pubDate ? new Date(pubDate).toISOString() : new Date().toISOString(),\n      scrapedFrom: 'google-news-rss'\n    }\n  });\n}\n\nreturn articles.length > 0 ? articles : [];"
      },
      "name": "Parse RSS Articles",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        920,
