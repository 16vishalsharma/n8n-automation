    {
      "parameters": {
        "jsCode": "// Parse CoinGecko response into metal + crypto prices\n// CoinGecko returns: {\"tether-gold\":{\"usd\":2900,\"inr\":242000},\"bitcoin\":{\"usd\":70000,\"inr\":5800000},\"ethereum\":{\"usd\":2000,\"inr\":167000}}\nconst data = items[0]?.json || {};\n\nconst goldXaut = data['tether-gold'] || {};\nconst btc = data.bitcoin || {};\nconst eth = data.ethereum || {};\n\n// XAUT (Tether Gold) = 1 troy oz of gold\nconst goldUsdPerOz = goldXaut.usd || 0;\nconst troyOzToGram = 31.1035;\n\n// Calculate USD to INR from BTC prices (most liquid pair)\nconst usdToInr = (btc.inr && btc.usd) ? Math.round((btc.inr / btc.usd) * 100) / 100 : 83.5;\n\nconst now = new Date().toISOString();\nconst date = now.split('T')[0];\n\nreturn [{\n  json: {\n    date,\n    gold_usd_per_oz: goldUsdPerOz,\n    gold_inr_per_gram: goldUsdPerOz > 0 ? Math.round((goldUsdPerOz / troyOzToGram) * usdToInr * 100) / 100 : 0,\n    gold_inr_per_10gram: goldUsdPerOz > 0 ? Math.round((goldUsdPerOz / troyOzToGram) * usdToInr * 10 * 100) / 100 : 0,\n    silver_usd_per_oz: 0,\n    silver_inr_per_gram: 0,\n    silver_inr_per_kg: 0,\n    bitcoin_usd: btc.usd || 0,\n    bitcoin_inr: btc.inr || 0,\n    ethereum_usd: eth.usd || 0,\n    ethereum_inr: eth.inr || 0,\n    usd_to_inr_rate: usdToInr,\n    fetchedAt: now,\n    source: 'coingecko'\n  }\n}];"
      },
