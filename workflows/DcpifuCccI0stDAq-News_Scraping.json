      "parameters": {
        "jsCode": "// Pass-through node that acts as a single reference point\n// for Build News Object. Both NewsAPI and RSS articles converge here.\n// Adds source tracking if not present.\nconst data = { ...$json };\nif (!data.scrapedFrom) {\n  data.scrapedFrom = 'newsapi';\n}\nreturn [{ json: data }];"
