      "parameters": {
        "jsCode": "// Build Google News RSS URLs for each topic\nreturn items.map(item => {\n  const topic = encodeURIComponent(item.json.topic);\n  return {\n    json: {\n      topic: item.json.topic,\n      rssUrl: `https://news.google.com/rss/search?q=${topic}&hl=en-IN&gl=IN&ceid=IN:en`\n    }\n  };\n});"
      },
