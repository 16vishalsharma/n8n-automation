    {
      "parameters": {
        "jsCode": "// Build Perplexity API request body for each topic\n// Perplexity Sonar does real-time web search for latest news\nconst topic = $json.topic;\n\nreturn [{\n  json: {\n    topic: topic,\n    requestBody: {\n      model: 'sonar',\n      messages: [\n        {\n          role: 'system',\n          content: 'You are a news aggregator. Return ONLY a valid JSON array of news articles. No extra text, no markdown, no explanation. Each article must have: title, description, source, author, url, publishedAt (ISO date string). Return exactly 5 articles.'\n        },\n        {\n          role: 'user',\n          content: `Find the 5 most recent and trending news articles about: ${topic}. Focus on today's news. Return as a JSON array.`\n        }\n      ],\n      temperature: 0.1,\n      max_tokens: 2000\n    }\n  }\n}];"
      },
      "name": "Build Perplexity Request",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        540,
        -120
      ],
      "id": "a1b2c3d4-0030-4000-8000-000000000030",
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.perplexity.ai/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer YOUR_PERPLEXITY_API_KEY"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{JSON.stringify($json.requestBody)}}",
        "options": {}
      },
      "name": "Fetch Perplexity News",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        720,
        -120
      ],
      "id": "a1b2c3d4-0031-4000-8000-000000000031",
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "// Parse Perplexity Sonar response into article format\nconst topic = $('Build Perplexity Request').item.json.topic;\nconst response = $json;\n\n// Extract the content from Perplexity response\nconst content = response.choices?.[0]?.message?.content || '';\n\n// Extract citations/sources if available\nconst citations = response.citations || [];\n\nlet articles = [];\n\ntry {\n  // Clean markdown fences if present\n  const cleaned = content.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n  const parsed = JSON.parse(cleaned);\n  \n  // Handle both array and object with articles key\n  const items = Array.isArray(parsed) ? parsed : (parsed.articles || parsed.news || [parsed]);\n  \n  articles = items.map((item, idx) => ({\n    json: {\n      title: item.title || '',\n      description: item.description || item.summary || '',\n      content: item.description || item.summary || item.content || '',\n      author: item.author || '',\n      source: { name: item.source || item.publisher || 'Perplexity' },\n      url: item.url || item.link || citations[idx] || '',\n      urlToImage: item.image || item.imageUrl || '',\n      publishedAt: item.publishedAt || item.date || item.published_at || new Date().toISOString(),\n      scrapedFrom: 'perplexity-sonar'\n    }\n  }));\n} catch (e) {\n  // If JSON parsing fails, create a single article from the text response\n  if (content.length > 20) {\n    articles = [{\n      json: {\n        title: `Trending: ${topic}`,\n        description: content.substring(0, 500),\n        content: content,\n        author: '',\n        source: { name: 'Perplexity' },\n        url: citations[0] || '',\n        urlToImage: '',\n        publishedAt: new Date().toISOString(),\n        scrapedFrom: 'perplexity-sonar'\n      }\n    }];\n  }\n}\n\nreturn articles.length > 0 ? articles : [];"
      },
      "name": "Parse Perplexity Articles",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        920,
        -120
      ],
      "id": "a1b2c3d4-0032-4000-8000-000000000032",
      "onError": "continueRegularOutput"
    }
