    {
      "parameters": {
        "jsCode": "// Validate + Deduplicate articles (in-memory across all items in batch)\nconst seen = new Set();\nreturn items.filter(item => {\n  const title = (item.json.title || '').trim();\n  const summary = (item.json.summary || '').trim();\n  const description = (item.json.description || '').trim();\n  \n  if (!title || title === '[removed]') return false;\n  if (!summary && !description) return false;\n  \n  const key = title.toLowerCase();\n  if (seen.has(key)) return false;\n  seen.add(key);\n  return true;\n});"
      },
