    {
      "parameters": {
        "jsCode": "// Extract readable text from HTML page\n// This node is OPTIONAL - enable it to get full article content\nconst html = $json.data || '';\nconst prevData = $('All Articles').item.json;\n\n// Remove scripts, styles, nav, footer, ads\nlet text = html\n  .replace(/<script[\\s\\S]*?<\\/script>/gi, '')\n  .replace(/<style[\\s\\S]*?<\\/style>/gi, '')\n  .replace(/<nav[\\s\\S]*?<\\/nav>/gi, '')\n  .replace(/<footer[\\s\\S]*?<\\/footer>/gi, '')\n  .replace(/<header[\\s\\S]*?<\\/header>/gi, '');\n\n// Extract text from article/main tags if they exist\nconst articleMatch = text.match(/<article[^>]*>([\\s\\S]*?)<\\/article>/) || text.match(/<main[^>]*>([\\s\\S]*?)<\\/main>/);\nif (articleMatch) {\n  text = articleMatch[1];\n}\n\n// Strip remaining HTML tags and clean up\ntext = text\n  .replace(/<[^>]*>/g, ' ')\n  .replace(/\\s+/g, ' ')\n  .replace(/&nbsp;/g, ' ')\n  .replace(/&amp;/g, '&')\n  .replace(/&lt;/g, '<')\n  .replace(/&gt;/g, '>')\n  .trim()\n  .substring(0, 3000); // Limit content length\n\nreturn [{\n  json: {\n    ...prevData,\n    content: text || prevData.content || prevData.description\n  }\n}];"
      },
      "name": "Extract Article Text",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1440,
        -20
